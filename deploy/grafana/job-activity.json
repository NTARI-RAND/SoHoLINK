{
  "__inputs": [],
  "__requires": [],
  "uid": "soholink-job-activity",
  "title": "SoHoLINK — Job Activity",
  "refresh": "30s",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Jobs",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "soholink_active_jobs",
          "legendFormat": "active jobs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Job Submissions per Minute",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "rate(soholink_jobs_submitted_total[5m]) * 60",
          "legendFormat": "{{workload_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Portal Request Rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(soholink_http_requests_total{handler=~\".*marketplace.*|.*job.*|.*provision.*\"}[5m])",
          "legendFormat": "{{handler}} {{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Total Jobs Submitted by Type",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "soholink_jobs_submitted_total",
          "legendFormat": "{{workload_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal"
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {}
}
