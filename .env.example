DATABASE_URL=postgres://postgres:changeme@host.docker.internal:5432/postgres?sslmode=disable
SESSION_PRIVATE_KEY=<128 hex chars — see deploy/README.md>
STRIPE_SECRET_KEY=sk_live_...
ORCHESTRATOR_TOKEN_SECRET=<64 hex chars — run: openssl rand -hex 32>
PORTAL_ADDR=:8080
PORTAL_BASE_URL=https://soholink.org
PORTAL_TEMPLATES_DIR=/app/web/templates
METRICS_ADDR=:9090
TUNNEL_TOKEN=<cloudflare tunnel token>
STRIPE_WEBHOOK_SECRET=
ORCHESTRATOR_INTERNAL_URL=http://orchestrator:8083
# Orchestrator
API_ADDR=:8082
INTERNAL_ADDR=:8083
SPIFFE_ENDPOINT_SOCKET=unix:///run/spire-server/private/api.sock
SPIRE_AGENT_JOIN_TOKEN=<generated by `spire-server token generate` — see deploy/register-entries.sh>
ALLOWLIST_PATH=/etc/soholink/allowlist.json
# Operator console (public, served by cmd/portal) + governance console (:8090, cmd/governance)
# COORDINATOR_ID is this coordinator's slug, bound into every FeeDeclaration and
# used by the public /fees page. Shared by cmd/portal and cmd/governance.
COORDINATOR_ID=soholink
# Coordinator Ed25519 signing key (64 bytes / 128 hex chars) — loaded ONLY by
# cmd/governance (:8090); NEVER by the public portal. Generate: run scripts/genkey.
COORDINATOR_SIGNING_KEY=<128 hex chars — cmd/governance only, never public>
# Governance server (cmd/governance). MUST bind loopback; defaults to 127.0.0.1:8090.
GOVERNANCE_ADDR=127.0.0.1:8090
GOVERNANCE_TEMPLATES_DIR=/app/web/templates
# Mail (SMTP) for operator email-2FA + governance messaging. When SMTP_HOST is
# unset both binaries fall back to a log/stub notifier (no mail is sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=no-reply@soholink.org
SMTP_USERNAME=
SMTP_PASSWORD=
# Testing
TEST_DATABASE_URL=postgres://postgres:changeme@localhost:5432/soholink_test?sslmode=disable
