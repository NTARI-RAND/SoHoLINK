# Signed artifacts — never convert line endings; signatures are
# computed over raw file bytes and any LF↔CRLF translation breaks
# signature verification.
deploy/allowlist/*.json -text

# Shell scripts must use LF; CRLF breaks shebang parsing on Linux
*.sh text eol=lf

# Go sources normalized to LF (committed blob gofmt-clean on CRLF checkouts)
*.go text eol=lf
