soholink.org {
	# WebSocket proxy — must be declared before the catch-all file_server
	reverse_proxy /ws/graph localhost:8080

	# API proxy
	reverse_proxy /api/* localhost:8080

	# Globe interface — serve single HTML file at /globe
	handle /globe {
		root * ui/globe-interface
		rewrite * /ntarios-globe.html
		file_server
	}

	# Flutter web SPA — serves everything else
	handle {
		root * mobile/flutter-app/build/web
		try_files {path} /index.html
		file_server
	}
}
