# ── Build stage ───────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o portal ./cmd/portal/

# ── Final stage ───────────────────────────────────────────────────────────────
FROM alpine:latest

WORKDIR /app
COPY --from=builder /src/portal ./portal
COPY --from=builder /src/web/ ./web/

EXPOSE 8080
CMD ["./portal"]
