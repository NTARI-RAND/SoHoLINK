# Public-site backend (waitlist + news feed). stdlib-only Go, static binary.
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/sitesvc ./cmd/sitesvc

FROM alpine:3.20
RUN apk add --no-cache ca-certificates && adduser -D -u 10001 sitesvc
COPY --from=build /out/sitesvc /usr/local/bin/sitesvc
USER sitesvc
EXPOSE 8095
ENTRYPOINT ["/usr/local/bin/sitesvc"]
